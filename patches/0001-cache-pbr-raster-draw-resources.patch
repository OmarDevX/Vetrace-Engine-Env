+const MIN_PBR_JOINT_CAPACITY: usize = 64;
+
+struct CachedPbrDraw {
+    uniform_buffer: Buffer,
+    material_buffer: Buffer,
+    joint_buffer: Buffer,
+    joint_capacity: usize,
+    texture_key: usize,
+    bind_group: Option<BindGroup>,
+    shadow_bind_group: Option<BindGroup>,
+}
+
+impl CachedPbrDraw {
+    fn new(device: &Device, index: usize) -> Self {
+        let uniform_buffer = device.create_buffer(&BufferDescriptor {
+            label: Some("pbr_cached_mvp"),
+            size: std::mem::size_of::<Uniforms>() as u64,
+            usage: BufferUsages::UNIFORM | BufferUsages::COPY_DST,
+            mapped_at_creation: false,
+        });
+        let material_buffer = device.create_buffer(&BufferDescriptor {
+            label: Some("pbr_cached_mat"),
+            size: std::mem::size_of::<MaterialUniforms>() as u64,
+            usage: BufferUsages::UNIFORM | BufferUsages::COPY_DST,
+            mapped_at_creation: false,
+        });
+        let joint_buffer = device.create_buffer(&BufferDescriptor {
+            label: Some("pbr_cached_joints"),
+            size: (std::mem::size_of::<[[f32; 4]; 4]>() * MIN_PBR_JOINT_CAPACITY) as u64,
+            usage: BufferUsages::UNIFORM | BufferUsages::COPY_DST,
+            mapped_at_creation: false,
+        });
+        let _ = index;
+        Self {
+            uniform_buffer,
+            material_buffer,
+            joint_buffer,
+            joint_capacity: MIN_PBR_JOINT_CAPACITY,
+            texture_key: usize::MAX,
+            bind_group: None,
+            shadow_bind_group: None,
+        }
+    }
+
+    fn ensure_joint_capacity(&mut self, device: &Device, min_capacity: usize) {
+        let needed = min_capacity.max(MIN_PBR_JOINT_CAPACITY);
+        if self.joint_capacity >= needed {
+            return;
+        }
+        let new_capacity = needed.next_power_of_two();
+        self.joint_buffer = device.create_buffer(&BufferDescriptor {
+            label: Some("pbr_cached_joints"),
+            size: (std::mem::size_of::<[[f32; 4]; 4]>() * new_capacity) as u64,
+            usage: BufferUsages::UNIFORM | BufferUsages::COPY_DST,
+            mapped_at_creation: false,
+        });
+        self.joint_capacity = new_capacity;
+        // Any bind group that referenced the old joint buffer is now invalid.
+        self.bind_group = None;
+        self.shadow_bind_group = None;
+    }
+}
